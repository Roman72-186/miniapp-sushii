{
  "version": 1,
  "lockFile": ".secrets.lock.local",
  "envFiles": [
    ".env",
    ".env.local"
  ],
  "jsoncFiles": [
    {
      "path": "opencode.jsonc",
      "keys": [
        "API_KEY",
        "CONTEXT7_API_KEY"
      ]
    }
  ],
  "literalPatterns": [
    {
      "path": "scripts/setup-pg-schema.js",
      "name": "DATABASE_URL fallback",
      "pattern": "postgresql:\\/\\/[^'\"\\s]+"
    }
  ],
  "freezeFiles": [
    ".env",
    ".env.local",
    "opencode.jsonc",
    "scripts/setup-pg-schema.js",
    ".secrets.lock.local"
  ]
}
