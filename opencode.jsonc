{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "TestSprite": {
      "type": "local",
      "command": ["npx", "-y", "@testsprite/testsprite-mcp@latest"],
      "enabled": true,
      "environment": {
        "API_KEY": "***REMOVED-TESTSPRITE-KEY***",
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "***REMOVED-CONTEXT7-KEY***"
      },
      "enabled": true
    }
  }
}
